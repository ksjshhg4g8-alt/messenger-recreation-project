{
  "tests": [
    {
      "name": "Config returns configured flag",
      "method": "GET",
      "path": "/?action=config",
      "expectedStatus": 200,
      "expectedBody": {"configured": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Start without token returns 503",
      "method": "POST",
      "path": "/?action=start",
      "body": {},
      "expectedStatus": 503,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Poll without payload returns 400",
      "method": "GET",
      "path": "/?action=poll",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action returns 400",
      "method": "GET",
      "path": "/?action=xxx",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
