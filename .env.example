# ============================================================
#  Настройки для запуска проекта на собственном сервере
#  Скопируй этот файл в .env и заполни своими значениями.
# ============================================================

# --- База данных PostgreSQL (ОБЯЗАТЕЛЬНО) ---
# Строка подключения к твоей базе.
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# --- Файловое хранилище S3 (ОБЯЗАТЕЛЬНО для загрузки фото/видео) ---
# Можно использовать AWS S3, Yandex Object Storage, MinIO и т.п.
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# --- Вход через мессенджер MAX (НЕОБЯЗАТЕЛЬНО) ---
# Нужны только если используешь авторизацию через MAX.
MAX_BOT_TOKEN=
MAX_BOT_USERNAME=

# ============================================================
#  Настройка фронтенда (файл .env в корне проекта для Vite)
# ============================================================
# Адрес твоего сервера с функциями. Если задан — сайт будет
# обращаться к твоему серверу вместо облака.
# Пример: VITE_API_BASE=https://api.your-domain.com
VITE_API_BASE=
